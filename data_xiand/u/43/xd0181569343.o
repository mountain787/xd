inventory_data ({"#~/gamelib/clone/item/weapon/1taomujian/1taomujian\ndata ([])\nname_cn \"桃木剑\"\ndesc \"\\n(主手)\\n\"\nname \"1taomujian\"\nmax_count 30\nred_baoshi ({})\namount 1\nyellow_baoshi ({})\nblue_baoshi ({})\nequiped 1\nitem_dura 240\n","#~/gamelib/clone/item/yushi/huposhi\ndata ([])\nname_cn \"琥珀石\"\ndesc \"里面还有一只倒霉的小虫子。有80%几率使无附加属性的装备转化成【优良】装备\\n\"\nname \"huposhi\"\nmax_count 30\nred_baoshi ({})\namount 18\nyellow_baoshi ({})\nitem_whoCanGet \"1\"\nblue_baoshi ({})\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/yushi/ganlanshi\ndata ([])\nname_cn \"橄榄石\"\ndesc \"这块坚硬的石头看起来还真有点像橄榄，你应该不会想吃他吧？能略微提升熔炼成功几率\\n\"\nname \"ganlanshi\"\nmax_count 30\nred_baoshi ({})\namount 18\nyellow_baoshi ({})\nitem_whoCanGet \"1\"\nblue_baoshi ({})\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/other/kaibanglingpai\ndata ([])\nname_cn \"开帮立派令牌\"\ndesc \"得令! 开立帮派!\\n\"\nname \"kaibanglingpai\"\nmax_count 30\nred_baoshi ({})\namount 4\nyellow_baoshi ({})\nitem_whoCanGet \"1\"\nblue_baoshi ({})\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/yushi/lvsongshi\ndata ([])\nname_cn \"绿松石\"\ndesc \"这块石头绿得不能再绿了，真想看看他的帽子是什么颜色。能些许提升熔炼成功几率\\n\"\nname \"lvsongshi\"\nmax_count 30\nred_baoshi ({})\namount 4\nyellow_baoshi ({})\nitem_whoCanGet \"1\"\nblue_baoshi ({})\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/material/maoyanshi\ndata ([])\nname_cn \"猫眼石\"\ndesc \"矿藏中的宝石。\\n\"\nname \"maoyanshi\"\nmax_count 30\nred_baoshi ({})\namount 1\nyellow_baoshi ({})\nitem_whoCanGet \"1\"\nblue_baoshi ({})\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/yushi/qingjinshi\ndata ([])\nname_cn \"青金石\"\ndesc \"这块沉重的石头表面有着金属般的光泽，你甚至都怀疑是一坨铁。能保证你的熔炼绝不会出错。\\n\"\nname \"qingjinshi\"\nmax_count 30\nred_baoshi ({})\namount 3\nyellow_baoshi ({})\nitem_whoCanGet \"1\"\nblue_baoshi ({})\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/yushi/jianjingshi\ndata ([])\nname_cn \"尖晶石\"\ndesc \"剔透的水晶外有让人心寒的刺尖，真不知道这块石头是怎么采集来的。能大大提升熔炼成功几率\\n\"\nname \"jianjingshi\"\nmax_count 30\nred_baoshi ({})\namount 3\nyellow_baoshi (