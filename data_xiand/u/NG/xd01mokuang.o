ewhoCanGet 1\n","#~/gamelib/clone/item/other/kaibanglingpai\ndata ([])\namount 15\nname_cn \"开帮立派令牌\"\ndesc \"得令! 开立帮派!\\n\"\nname \"kaibanglingpai\"\nmax_count 30\nyellow_baoshi ({})\nblue_baoshi ({})\nred_baoshi ({})\n","#~/gamelib/clone/item/yushi/lvsongshi\ndata ([])\namount 3\nname_cn \"绿松石\"\ndesc \"这块石头绿得不能再绿了，真想看看他的帽子是什么颜色。能些许提升熔炼成功几率\\n\"\nname \"lvsongshi\"\nmax_count 30\nyellow_baoshi ({})\nblue_baoshi ({})\nred_baoshi ({})\nitem_whoCanGet \"1\"\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/yushi/binglanyushi\ndata ([])\namount 3\nname_cn \"冰蓝玉石\"\ndesc \"来自蔚蓝的大海，凝聚海水之精华，剔透晶莹。能提高炼化中增加属性成功的几率至100%\\n\"\nname \"binglanyushi\"\nmax_count 30\nyellow_baoshi ({})\nblue_baoshi ({})\nred_baoshi ({})\nitem_whoCanGet \"1\"\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/yushi/qingjinshi\ndata ([])\namount 2\nname_cn \"青金石\"\ndesc \"这块沉重的石头表面有着金属般的光泽，你甚至都怀疑是一坨铁。能保证你的熔炼绝不会出错。\\n\"\nname \"qingjinshi\"\nmax_count 30\nyellow_baoshi ({})\nblue_baoshi ({})\nred_baoshi ({})\nitem_whoCanGet \"1\"\nitem_TimewhoCanGet 1\n","#~/gamelib/clone/item/taskaward/liewenyin\ndata ([])\namount 1\nname_cn \"【宝】列瘟印\"\ndesc \"蛊印，毒性巨大\\n\"\nname \"liewenyin\"\nequiped 1\nmax_count 30\nitem_cur_dura 1000\nyellow_baoshi ({})\nblue_baoshi ({})\nred_baoshi ({})\nitem_dura 1000\n","#~/gamelib/clone/item/water/yaochishui\ndata ([])\namount 1\nname_cn \"瑶池水\"\ndesc \"这是一瓶补充法力的瑶池水，每次饮用，可以补充法力1200点。\\n阵营限制：妖魔 人类 \\n职业限制：影鬼 巫妖 狂妖 诛仙 羽士 剑仙 \\n等级限制：15级\\n\"\nname \"yaochishui\"\nprofe_limit ([\"yushi\":\"羽士\",\"jianxian\":\"剑仙\",\"zhuxian\":\"诛仙\",\"yinggui\":\"影鬼\",\"wuyao\":\"巫妖\",\"kuangyao\":\"狂妖\",])\nlevel_limit 15\nmax_count 30\nyellow_baoshi ({})\nblue_baoshi ({})\nred_baoshi ({})\nitem_whoCanGet \"1\"\nitem_TimewhoCanGet 1\neat_flag 1\nrace_limit ([\"monst\":\"妖魔\",\"human\":\"人类\",])\nadd_supplay ([\"mofa_supply\":1200,\"life_supply\":0,])\n","#~/gamelib/clone/item/duanzao/25jiefengmianju\ndata ([])\namount 1\nname_cn \"【熔】结风面具\"\ndesc \"\\n\"\nname \"25jiefengmianju\"\nequiped 1\nmax_cou