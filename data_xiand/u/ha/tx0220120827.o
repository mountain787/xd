inventory_data ({"#~/gamenv/clone/item/xunbao/qsnvjie\ndata ([\"plus\":([\"lover_id\":0,\"eff_dura\":1483,\"max_dura\":1483,\"lover_name\":0,\"lover_sex\":0,\"mend_time\":9,]),])\ndesc \"恰是一对恋人两手相牵，情依不舍。闪着钻石般璀璨的目光，仿佛在告诉世人，相爱不是神话，而是连神仙都要忌羡的美丽。\\n\"\nname_cn \"牵手对戒之女戒\"\nname \"qsnvjie\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/xunbao/baowenyupei\ndata ([\"plus\":([\"max_dura\":1870,\"eff_dura\":1870,\"mend_time\":9,]),])\ndesc \"由上等白玉雕制而的豹纹玉佩。\\n(需要拆招卸力100级)\\n\"\nname_cn \"五灵豹纹玉佩\"\nname \"baowenyupei\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/xunbao/tzwulingzhanxue\ndata ([\"plus\":([\"mend_time\":9,\"eff_dura\":966,\"max_dura\":3000,]),])\ndesc \"以极软圣兽皮毛缝制，并镶嵌资金珠。/n(需要拆招卸力200级)\\n\"\nname_cn \"五灵战靴\"\nname \"tzwulingzhanxue\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/xunbao/tzwulinghufu\ndata ([\"plus\":([\"max_dura\":2345,\"eff_dura\":2345,\"mend_time\":9,]),])\ndesc \"由五灵石打制而成，具有一定的防护。/n(需要拆招卸力200级)\\n\"\nname_cn \"五灵护符\"\nname \"tzwulinghufu\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/xunbao/tzwulingpifeng\ndata ([\"plus\":([\"mend_time\":9,\"eff_dura\":794,\"max_dura\":2828,]),])\ndesc \"赤红色缎袍，金丝绣龙，亦刚亦柔，十分名贵。/n(需要拆招卸力200级)\\n\"\nname_cn \"五灵披风\"\nname \"tzwulingpifeng\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wudang/jinshejianXfXl4\ndata ([\"plus\":([\"max_dura\":1910,\"eff_dura\":1910,\"mend_time\":9,]),])\ndesc \"此剑如一条蛇盘曲而成。剑柄如蛇尾，剑尖分叉，如蛇吐信。通体泛出暗光。\\n\"\nname_cn \"「肆」金龙蛇剑\"\nname \"jinshejianXfXl4\"\nskill \"sword\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/xunbao/tzwulingzhanjia\ndata ([\"plus\":([\"mend_time\":9,\"eff_dura\":1576,\"max_dura\":3162,]),])\ndesc \"精铁中提炼出来的纯钢制成的钢甲，坚硬度极高，且非常轻便。/n(需要拆招卸力200级)\\n\"\nname_cn \"五灵战甲\"\nname \"tzwulingzhanjia\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/xunbao/tzwulingmianju\ndata ([\"plus\":([\"mend_time\":9,\"eff_dura\":863,\"max_dura\":2449,]),])\ndesc \"巧夺天工的神奇面具，坚韧异常，防护绝佳。/n(需要拆招卸力200级)\\n\"\nname_cn \"五灵面具\"\nname \"tzwulingmianju\"\namount 1\nequiped 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/cloth/tiewangjia\ndata ([\"plus\":([\"eff_dura\":632,\"max_dura\":632,\"mend_time\":8,\"userid\":\"1\",\"drop_time\":1711718972,]),])\ndesc \"百炼纲丝交织编成，坚硬无比。\\n\"\nname_cn \"铁网甲\"\nname \"tiewangjia\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wabao/beijing_tiegao\ndata ([])\ndesc \"只能在该地图使用的铁镐，用来挖宝非常方便，比用手挖掘效率高的多。\\n\"\nname_cn \"铁镐-京师\"\nname \"beijing_tiegao\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wabao/beijing_tiegao\ndata ([])\ndesc \"只能在该地图使用的铁镐，用来挖宝非常方便，比用手挖掘效率高的多。\\n\"\nname_cn \"铁镐-京师\"\nname \"beijing_tiegao\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wabao/beijing_tiegao\ndata ([])\ndesc \"只能在该地图使用的铁镐，用来挖宝非常方便，比用手挖掘效率高的多。\\n\"\nname_cn \"铁镐-京师\"\nname \"beijing_tiegao\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wabao/beijing_tiegao\ndata ([])\ndesc \"只能在该地图使用的铁镐，用来挖宝非常方便，比用手挖掘效率高的多。\\n\"\nname_cn \"铁镐-京师\"\nname \"beijing_tiegao\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wabao/beijing_tiegao\ndata ([])\ndesc \"只能在该地图使用的铁镐，用来挖宝非常方便，比用手挖掘效率高的多。\\n\"\nname_cn \"铁镐-京师\"\nname \"beijing_tiegao\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/shoes/wucaiji\ndata ([\"plus\":([\"eff_dura\":774,\"max_dura\":774,\"mend_time\":7,\"drop_time\":1711752369,\"userid\":\"1\",]),])\ndesc \"古代样式的木屐，鞋底有齿，鞋上有华丽的彩绘，并以五彩丝带系住。\\n\"\nname_cn \"五彩屐\"\nname \"wucaiji\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wudang/jindiaodao\ndata ([\"plus\":([\"max_dura\":1941,\"eff_dura\":1941,\"mend_time\":9,]),])\ndesc \"刀身呈淡紫色，刀柄以貂形所铸。内藏暗器，杀伤力极大。\\n\"\nname_cn \"金貂刀\"\nname \"jindiaodao\"\nskill \"blade\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/other/xiaosha_5\ndata ([\"plus\":([\"power\":5,]),])\ndesc \"使用该令牌可以减少5次的被杀数，使用以后令牌便会消失，请拥有它的人谨慎使用。\\n\"\nname_cn \"消杀令（5）\"\nname \"xiaosha_5\"\namount 1\nbangpai_desc \"\"\n","#~/gamenv/clone/item/wabao/be