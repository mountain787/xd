inherit WAP_BOOK;
protected void create(){
	name=object_name(this_object());
	name_cn="【杀】伏击";
	unit="本";
	picture=name;
	desc="袭击敌人，直接造成伤害的攻击技能\n";
	set_item_canDrop(1);
	set_item_canGet(1);
	set_item_canTrade(1);
	set_item_canSend(1);
	set_item_canStorage(1);
	value=50;
	skill_bname="fuji";
	level_limit=1;
	profe_read_limit="影鬼";
