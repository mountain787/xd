#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_BOOK;
protected void create(){
	name=object_name(this_object());
	name_cn="【诅】灵魂封印";
	unit="本";
	picture=name;
	desc="封印敌人的灵魂，降低敌人的智力\n";
	set_item_canDrop(1);
	set_item_canGet(1);
	set_item_canTrade(1);
	set_item_canSend(1);
	set_item_canStorage(1);
	value=50;
	skill_bname="linghunfengying";
	level_limit=39;
	profe_read_limit="羽士";
}
int read(){
	int result=::read();
	if(read_flag==0){
		remove();
	}
	return result;
}
