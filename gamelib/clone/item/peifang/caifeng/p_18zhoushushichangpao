inherit WAP_BOOK;
protected void create(){
	name=object_name(this_object());
	name_cn="【图样】咒术师长袍";
	unit="本";
	picture=name;
	desc="上面记载了咒术师长袍的制造方法\n";
	set_item_canDrop(1);
	set_item_canGet(1);
	set_item_canTrade(1);
	set_item_canSend(1);
	set_item_canStorage(1);
	set_peifang_kind("caifeng");
	set_peifang_type("cloth");
	peifang_id=21;
	level_limit=18;
	viceskill_level=30;
}
int read(){
	int result=::caifeng_read();
	if(read_flag==0){
		remove();
	}
	return result;
}
