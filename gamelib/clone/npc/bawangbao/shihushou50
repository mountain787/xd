#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit GAMELIB_NPC;
void create(){
	name=object_name(this_object());
	desc="头似雄狮，身似猛虎，眼露寒光\n";
	set_raceId("third");
	set_profeId("beast");
	sex="male";
	gender="雄";
	pronoun="它";
	_npcLevel=100;
	name_cn="狮虎兽";
	_meritocrat=1;
	setup_npc();
}
string query_words(){
	string s = ::query_words();
	s += TASKD->query_words(this_player(),this_object());
	return s;
}
string query_links(void|int count){
	return ::query_links(count);
}
void fight_die(){
	::fight_die();
}
