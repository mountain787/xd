#include <gamelib/include/gamelib.h>
inherit GAMELIB_NPC;
void create(){
	name=object_name(this_object());
	_boss=1;
	_flushtime=36000;
	name_cn="巨云怪";
	desc="翻起巨型云水，吞灭一切\n";
	set_raceId("third");
	set_profeId("beast");
	picture="1";
	_npcLevel=65;
	set_base_think(200);
	set_base_dex(200);
	set_base_str(500);
	set_base_life(560000);
	this_object()->query_life_max();
	set_base_baoji(19);
	set_base_hitte(100);
	set_base_dodge(13);
	setup_npc();
	set_heart_beat(1);
}
string query_words(){
	string s = ::query_words();
	s += TASKD->query_words(this_player(),this_object());
	return s;
}
string query_links(void|int count){
	return ::query_links(count);
}
void fight_die(){
	::fight_die();
}
