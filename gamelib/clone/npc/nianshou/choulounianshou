#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit GAMELIB_NPC;
protected void create(){
	name=object_name(this_object());
	_boss=1;
	_flushtime=36000;
	name_cn="丑陋年兽";
	desc="头长触角，凶残异常\n";
	set_raceId("third");
	set_profeId("beast");
	picture="nianshou";
	_npcLevel=10;
	set_base_think(100);
	set_base_dex(20);
	set_base_str(50);
	set_base_life(100000);
	this_object()->query_life_max();
	set_base_baoji(2);
	set_base_hitte(50);
	set_base_dodge(2);
	setup_npc();
	set_heart_beat(1);
}
string query_words(){
	string s = ::query_words();
	s += TASKD->query_words(this_player(),this_object());
	return s;
}
string query_links(void|int count){
	return ::query_links(count);
}
void fight_die(){
	::fight_die();
}
