#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_ROOM;
int clear = 0;
protected void create(){
	name=object_name(this_object());
	set_room_type("fb");
	name_cn="探骨小路";
	desc="\n";
	add_items(({ROOT "/gamelib/clone/npc/bwmk/bawangbaojinwei"}));
	add_items(({ROOT "/gamelib/clone/npc/bwmk/jingweijunshouling"}));
	add_items(({ROOT "/gamelib/clone/npc/bwmk/mohunshizhe"}));
	add_items(({ROOT "/gamelib/clone/npc/bwmk/mowangshouwei"}));
	add_items(({ROOT "/gamelib/clone/npc/boss/shangtangzhihun"}));
}
string query_links(){
	object player=this_player();
	string tmp="";
	tmp += "[去往腐败石门:fb_entry bawangmoku 14 1]\n";
	if(check_if_clear() == 1)
		tmp += "[去往骷髅穴:fb_entry bawangmoku 16 1]\n";
	else
		tmp += "去往骷髅穴\n";
	return tmp;
}
int check_if_clear(){
	if(clear == 1)
		return 1;
	array(object) all_obj = all_inventory(this_object());
	foreach(all_obj,object ob){
		if(ob->is("npc")){
			clear = 0;
			break;
		}
		else
			clear = 1;
	}
	return clear;
}