#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_ROOM;
string room_race="third";
protected int room_level=0;
protected void create(){
	name=object_name(this_object());
	name_cn="千雪镇";
	desc="\n";
	exits["east"]=ROOT "/gamelib/d/home/xd9/qianxuehu/qianxuehupan";
	exits["west"]=ROOT "/gamelib/d/home/xd9/qianxuehu/qianxuechangjie";
}
string query_links(){
	string tmp="";
	string name = this_object()->query_name();
	tmp+= HOMED->banner_slot(name);
	tmp+= HOMED->display_flats(name);
	tmp+= "\n\n\n\n";
	return tmp;
}
