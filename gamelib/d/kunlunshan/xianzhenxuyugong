#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_ROOM;
string room_race="human";
protected int room_level=71;
void create(){
	name=object_name(this_object());
	name_cn="仙阵【玉虚宫】";
	desc="\n";
	exits["south"]=ROOT "/gamelib/d/kunlunshan/shierchanglang";
}
string query_links()                                                                                                         
{   
	object player=this_player();
	string tmp="";
	if(player->query_raceId()==room_race&&player->query_level()>=10)
		tmp+="[仙阵【黄家庄】:qge74hye huangjiazhuang/jianzhenhuangjiazhuang]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=15)
		tmp+="[仙阵【将军墓】:qge74hye jiangjunmu/xianzhenjiangjunmu]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=20)
		tmp+="[仙阵【两镜湖】:qge74hye liangjinghu/xianzhenliangjinghu]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=25)
		tmp+="[仙阵【蓬莱水阁】:qge74hye plshuige/xianzhenpenglaishuige]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=30){
		tmp+="[仙阵【牧野】:qge74hye muye/xianzhenmuye]\n";
		if(CITYD->query_captured("chaogecheng")=="human")
			tmp+="[仙阵【朝歌】:city_qge74hye chaogecheng/yaozhengchaoge chaogecheng]\n";
		if(CITYD->query_captured("xiqicheng")=="human")
			tmp+="[仙阵【西岐】:city_qge74hye xiqicheng/xianzhen xiqicheng]\n";
	}
	if(player->query_raceId()==room_race&&player->query_level()>=40)
		tmp+="[仙阵【外海】:qge74hye waihai/xianzhenwaihai]\n";
	return tmp;
}

