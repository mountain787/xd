#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_ROOM;
string room_race="human";
protected int room_level=450;
void create(){
	name=object_name(this_object());
	name_cn="仙阵【牧野】";
	desc="\n";
	exits["east"]=ROOT "/gamelib/d/muye/huixianyizhan";
}
string query_links() 
{   
	object player=this_player();
	string tmp="";
	if(player->query_raceId()==room_race&&player->query_level()>=30)
		tmp+="[仙阵【玉虚宫】:qge74hye kunlunshan/xianzhenxuyugong]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=40)
		tmp+="[仙阵【流光平原】:qge74hye liuguangpingyuan/xianzhenliuguangping]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=50)
		tmp+="[仙阵【蓬莱仙境】:qge74hye plxianjing/xianzhenplxianjing]\n";
	return tmp;
}
