#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_ROOM;
string room_race="monst";
static int room_level=497;
void create(){
	name=object_name(this_object());
	name_cn="妖阵【牧野】";
	desc="\n";
	exits["west"]=ROOT "/gamelib/d/muye/qixianyizhan";
}
string query_links() 
{   
	object player=this_player();
	string tmp="";
	if(player->query_raceId()==room_race&&player->query_level()>=30)
		tmp+="[妖阵【碧游宫】:qge74hye jinaodao/yaozhenbiyougong]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=40)
		tmp+="[妖阵【流光平原】:qge74hye liuguangpingyuan/yaozhenliuguangpingy]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=50)
		tmp+="[妖阵【蓬莱仙境】:qge74hye plxianjing/yaozhenplxianjing]\n";
	return tmp;
}
