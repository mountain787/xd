#include <globals.h>
#include <gamelib/include/gamelib.h>
inherit WAP_ROOM;
string room_race="monst";
protected int room_level=1204;
void create(){
	name=object_name(this_object());
	name_cn="武阁";
	desc="\n";
	exits["south"]=ROOT "/gamelib/d/plxianjing/paimaihang2";
	exits["north"]=ROOT "/gamelib/d/plxianjing/myczahuopu";
}
int is_peaceful()
{
	return 1;
}
string query_links(){
	object player=this_player();
	string tmp="";
	if(player->query_raceId()==room_race){
		if(player->packageLevel<=90)
			tmp+="藏宝箱：[存:user_package]|[取:user_repackage]|[购买:user_package_buy]\n";
		else
			tmp+="藏宝箱：[存:user_package]|[取:user_repackage]\n";
	}
	return tmp;
}
