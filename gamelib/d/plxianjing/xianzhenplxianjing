int is_peaceful()
{
	return 1;
}
string query_links() 
{   
	object player=this_player();
	string tmp="";
	if(player->query_raceId()==room_race&&player->query_level()>=50)
		tmp+="[д»ҷйҳөгҖҗзү§йҮҺгҖ‘:qge74hye muye/xianzhenmuye]\n";
	if(player->query_raceId()==room_race&&player->query_level()>=58)
		tmp+="[д»ҷйҳөгҖҗи“¬иҺұе№»еўғгҖ‘:qge74hye penglaihuanjing/xianzhenplhj]\n";
	return tmp;
}
