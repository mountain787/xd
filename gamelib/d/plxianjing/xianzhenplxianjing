protected void create(){
	name=object_name(this_object());
	name_cn="д»ҷйҳөгҖҗи“¬иҺұд»ҷеўғгҖ‘";
	desc="\n";
	exits["south"]=ROOT "/gamelib/d/plxianjing/lingxianzhen";
	exits["north"]=ROOT "/gamelib/d/plxianjing/bingyueyunwu";
